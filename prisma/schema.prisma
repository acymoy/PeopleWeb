// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// TODO: Add payments to schema (User, and new table Payment)
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  passwordHash  String?
  emailVerified DateTime? @map("email_verified")
  createdAt     DateTime  @default(now()) @map("created_at")

  accounts         Account[]
  sessions         Session[]
  graphs           Graph[]
  graphMemberships GraphMembership[]
  personNodes      PersonNode[]
  edges            Edge[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Graph {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  isPublic    Boolean  @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @map("updated_at")

  nodes       PersonNode[]
  edges       Edge[]
  ownerId     String            @map("owner_id")
  memberships GraphMembership[]
  owner       User              @relation(fields: [ownerId], references: [id])

  @@map("graphs")
}

model PersonNode {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  name        String
  email       String?
  phone       String?
  description String
  image       String?
  color       String?
  positionX   Float?
  positionY   Float?

  createdBy String
  edgesFrom Edge[] @relation("EdgeSource")
  edgesTo   Edge[] @relation("EdgeTarget")
  creator   User   @relation(fields: [createdBy], references: [id])
  graph     Graph  @relation(fields: [id], references: [id])
}

model Edge {
  id         Int       @id @default(autoincrement())
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")
  isDirected Boolean   @default(false)
  label      String?

  createdBy    String
  sourceId     Int        @map("source_id")
  targetId     Int        @map("target_id")
  sourceNodeId PersonNode @relation("EdgeSource", fields: [sourceId], references: [id])
  targetNodeId PersonNode @relation("EdgeTarget", fields: [targetId], references: [id])
  graph        Graph      @relation(fields: [id], references: [id])
  creator      User       @relation(fields: [createdBy], references: [id])
}

model GraphMembership {
  id        Int        @id @default(autoincrement())
  privilege Membership @default(VIEWER)

  userId  String @map("user_id")
  graphId Int    @map("graph_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  graph   Graph  @relation(fields: [graphId], references: [id], onDelete: Cascade)

  @@unique([graphId, userId])
}

enum Membership {
  VIEWER
  OWNER
  EDITOR
  MIN_EDITOR
}
